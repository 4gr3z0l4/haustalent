---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'HAUS TALENT',
  description = 'Construcción y rehabilitación de edificios singulares e instalaciones deportivas.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>