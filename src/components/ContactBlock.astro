---
import { siteData } from '../content/site';
---

<section
  id="contact"
  class="bg-brand-blue text-brand-ivory"
>
  <div class="container-shell pt-14 pb-24 md:pt-16 md:pb-28">
    <div class="grid gap-14 border-t border-brand-line pt-10 md:grid-cols-[0.9fr_1.5fr] md:gap-20 md:pt-14">
      <div>
        <p class="text-[11px] uppercase tracking-[0.32em] text-brand-gold">
          Contacto
        </p>
      </div>

      <div class="grid gap-10 md:gap-14">
        <div class="max-w-2xl">
          <p class="mt-8 max-w-xl text-base leading-8 text-brand-muted md:text-lg md:leading-9">
            {siteData.contactIntro}
          </p>
        </div>

        <div class="grid gap-8 border-t border-brand-line pt-8 md:grid-cols-2 md:gap-10">
          <div class="grid gap-3">
            <p class="text-[11px] uppercase tracking-[0.28em] text-brand-gold/90">
              Correo
            </p>
            <a
              href={`mailto:${siteData.email}`}
              class="text-xl text-brand-ivory transition-colors duration-300 hover:text-brand-gold"
            >
              {siteData.email}
            </a>
          </div>

          <div class="grid gap-3">
            <p class="text-[11px] uppercase tracking-[0.28em] text-brand-gold/90">
              Dirección
            </p>
            <p class="max-w-sm text-base leading-8 text-brand-muted md:text-lg">
              {siteData.address}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>