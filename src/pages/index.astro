---
import MainLayout from '../layouts/MainLayout.astro';
import { siteData } from '../content/site';
---

<MainLayout
  title="HAUS TALENT"
  description="Construcción y rehabilitación de edificios singulares e instalaciones deportivas."
>
  <main class="min-h-screen bg-brand-blue text-brand-ivory">
    <section class="flex min-h-screen items-center justify-center px-6 text-center">
      <div class="max-w-3xl">
        <p class="mb-4 text-sm uppercase tracking-[0.35em] text-brand-gold/80">
          {siteData.tagline}
        </p>
        <h1 class="font-serif text-5xl tracking-wide md:text-7xl">
          {siteData.brand}
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-brand-ivory/80 md:text-xl">
          {siteData.claim}
        </p>
      </div>
    </section>
  </main>
</MainLayout>